# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Cargo.lock IS committed: this workspace produces a wheel (imspy_connector) + CLI
# binaries, so it is an application for lockfile purposes — the committed lock is the
# reproducibility anchor for the wheel and the CI `locked` leg (RELEASING.md §4).
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

__pycache__/

# Poetrys lock file
*.lock
# ...but DO track the workspace-root Cargo lockfile (wheel reproducibility, CI `locked` leg)
!/Cargo.lock

# IDE files
.vscode/
.idea/

# Python build artifacts
dist/
build/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/
.pytest_cache/

# Python virtual environments
.venv/
**/.venv/
venv/

# Training/run artifacts
*.log
checkpoints/
results/
*.tdf

# Test/example data (large files)
imspy/examples/T*/
*.db

# generated documentation
imspy/docs/build

# local design/plan/review docs — kept out of the repo (live locally only)
*.codex-review.md
packages/imspy-simulation/TIER2_REWINDOW.md
packages/imspy-simulation/THERMO_RAW_AUTHORING.md


# transient codex review reference (originals)
.codex-ref/
